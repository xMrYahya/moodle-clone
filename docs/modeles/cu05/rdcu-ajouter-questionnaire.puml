@startuml
title RDCU Ajouter un questionnaire

participant ":QuestionnaireController" as controller
participant ":QuestionnaireModele" as questionnaireModele
participant "q:Questionnaire" as questionnaire

-> controller : ajouterQuestionnaire(nom:String, description:String, actif:boolean):String
note right: GRASP: Controller
activate controller
controller -> questionnaireModele : creerQuestionnaire(groupeId:String, nom:String, description:String, actif:boolean):Questionnaire
note right: GRASP: Expert
activate questionnaireModele
create questionnaire
