@startuml
hide footbox
title RDCU - Selectionner modifier un questionnaire

participant ":QuestionnaireController" as controller
participant ":QuestionnaireModele" as questionnaireModele
participant "questionnaireTemp:Questionnaire" as temp

-> controller ++: selectionModifierQuestionnaire(nom:String):Questionnaire
note right: GRASP: Controller
controller -> questionnaireModele ++: modifierQuestionnaire(nom:String):Questionnaire
note right: GRASP: Expert
questionnaireModele -> temp ++: mettreAJourAvec(q:Questionnaire)
note right: GRASP: Expert
deactivate temp
questionnaireModele --> controller --: questionnaireTemp:Questionnaire
<-- controller --: questionnaireTemp:Questionnaire

@enduml
