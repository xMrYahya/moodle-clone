@startuml
title Afficher - Détails d'un cours
skinparam Style strictuml
skinparam sequenceMessageAlign center

participant ":CoursController"  as CoursController
participant "sga:accesSGA" as sga

 -> CoursController : afficherDetailsCours(idGroupe: String) : cours
note right: controlleur
activate CoursController
CoursController -> sga : getEtudiantsParGroupe(idGroupe: String) : Étudiant[]
sga -->> CoursController : ListeEtudiants : Étudiant[]

deactivate CoursController
@enduml