@startuml
title RDCU – Demarrer Ajout Cours
skinparam Style strictuml
skinparam sequenceMessageAlign center

participant ":Enseignant"  as enseignant
participant "sga:accesSGA" as sga

 -> enseignant : demarrerAjoutCours()
activate enseignant
enseignant -> sga : getCours(teacher_id:string, token:string): Groupe-Cours[]
activate sga
sga -->> enseignant :  listeGC:Groupe-Cours[]

deactivate sga

deactivate enseignant
@enduml