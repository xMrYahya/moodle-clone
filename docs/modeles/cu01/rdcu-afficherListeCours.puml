@startuml
title RDCU - afficher liste des cours
skinparam Style strictuml
skinparam sequenceMessageAlign center

participant "hc:HomeController"  as hc
participant "sga:accesSGA" as sga

 -> hc : afficherListeCours() : Cours[]
note right: GRASP: Controller
activate hc
hc -> sga : getListeCours(teacher_id:string): Cours[]
note right: GRASP: Expert
activate sga
sga -->> hc : ListeCours : cours[]

deactivate sga
 <<-- hc : listeCours : cours[] 

deactivate hc
@enduml