@startuml
hide footbox
title RDCU - Ajouter une question Mise en correspondance

participant "qc:QuestionsController" as QC
participant ":CoursModele" as CM
participant "q:QuestionMiseEnCorrespondance" as Q

-> QC : ajouterQuestionMiseEnCorrespondance(typeQuestion : String, nom : String, enonce : String,\n retroactionValide : String, retroactonInvalide : String : tagsValides : String[],\n ICI CHANGER)
note right: GRASP: Controller
activate QC
QC -> QC ++: ajouterQuestionParType(typeQuestion : String, nom : String, enonce : String,\n retroactionValide : String, retroactonInvalide : String : tagsValides : String[],\n ICI CHANGER ) : void
note right: GRASP: Controller


QC -> QC ++: validerChampsObligatoires(nom:String, enonce:String) : void
note right: GRASP: Expert

deactivate QC

QC -> QC ++: validerNomQuestionUnique(idGroupe: String, nom: String) : void
note right: GRASP: Expert

QC -> QC ++: nomQuestionExiste(idGroupe: String, nom: String) : boolean
note left: Lance une exception si nomQuestionExiste est true
note right: GRASP: Expert


QC -> CM ++: obtenirQuestionsDuCours(idGroupe) : Question[]
note right: GRASP: Expert
CM --> QC --: questions: Question[]
deactivate QC
deactivate QC

QC -> QC ++: validerTagsObligatoires(tags: String[]) : tags : String[]
note right: GRASP: Expert
deactivate QC

alt Donnees valides et nom unique (Aucune exception n'est lancée dans les fonctions précédentes)
  QC -> QC ++: creerQuestionAutreType(typeQuestion : String, nom : String, enonce : String,\n retroactionValide : String, retroactonInvalide : String : tagsValides : String[],\n paires : String[]) : void
  note right: GRASP: CREATOR et Expert

  QC -> QC ++: lirePaireCorrespondance(paires : String[] ) : PairDeCorresponance[]
  note right: GRASP: Creator et Expert
  deactivate QC 

  QC -> Q **: <<create>> QuestionMiseEnCorrespondance(nom : String, enonce : String,\n, retroactionValide : String, retroactionInvalide : String \n, tags String[], paires : PairDeCorrespondance[])
  note right: GRASP: Creator

  deactivate QC
  QC -> CM : ajouterQuestionAuCours(groupId : String, q : Question) : void
  note right: GRASP: Expert
  activate CM
  deactivate CM

    <-- QC : confirmation d'ajout
else Nom deja utilise ou donnees invalides
    <-- QC : Signalement d'erreur ajout question

end
deactivate QC
deactivate QC

@enduml
