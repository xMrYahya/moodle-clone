@startuml
hide footbox
title RDCU - Modifier une question choix multiple

participant "qc:QuestionsController" as QC
participant "cm:CoursModele" as CM
participant "q:QuestionChoixMultipleModele" as Q

-> QC : modifierQuestionChoixMultiple(nomOriginal : String,\n nom : String, enonce : String, reponses : String[], seulementUnChoix : bool,\n retroactionValide : String, retroactionInvalide : String, tags : String[])
note right: GRASP: Controller
activate QC

QC -> CM : obtenirQuestionParNom(idGroupe : String, nomOriginal : String)
note right: GRASP: Expert
activate CM
CM --> QC : questionExistante : AnyQuestion
deactivate CM

QC -> QC : validerChampsObligatoires(type, nom, enonce)
note right: GRASP: Expert

QC -> CM : nomQuestionExisteSauf(idGroupe : String, nom : String, nomOriginal : String)
note right: GRASP: Expert
activate CM
CM --> QC : nomExiste : boolean
deactivate CM

alt Nom unique et donnees valides
  QC -> QC : lireReponsesChoixMultiple(reponses)
  note right: GRASP: Expert

  create Q
  QC -> Q : <<create>> QuestionChoixMultipleModele(nom, enonce,\n retroactionValide, retroactionInvalide, tags, seulementUnChoix, reponses)
  note right: GRASP: Creator
  activate Q
  deactivate Q

  QC -> CM : modifierQuestionDuCours(idGroupe : String, nomOriginal : String, q)
  note right: GRASP: Expert
  activate CM
  deactivate CM

  <-- QC : afficherConfirmationModification
else Nom deja utilise ou donnees invalides
  <-- QC : signalerErreurModification
end

deactivate QC
@enduml