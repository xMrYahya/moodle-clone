@startuml
hide footbox
title RDCU pour Ajouter une question Vrai ou Faux

participant "qc:QuestionsController" as QC
participant "qs:QuestionsStore" as QS
participant "q:QuestionVraiFaux" as Q

-> QC : ajouterQuestionVraiFaux(nom : String, enonce : String,\n reponse : bool, retroactionValide : String,\n retroactionInvalide : String, tags : String[])
activate QC

QC -> QS : questionNameExists(nom)
activate QS
QS --> QC : nomExiste:boolean
deactivate QS

alt Nom de question unique
    create Q
    QC -> Q : <<create>> QuestionVraiFaux(nom, enonce, reponse,\n retroactionValide, retroactionInvalide, tags)
    activate Q
    deactivate Q

    QC -> QS : addQuestion(q)
    activate QS
    deactivate QS

    <-- QC : confirmationAjout(listeQuestions):String
else Nom de question deja utilise
    <-- QC : signalerErreurNomExistant():String
end

deactivate QC
@enduml