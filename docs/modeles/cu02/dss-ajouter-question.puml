@startuml
title Ajouter une question
actor ":Enseignant" as e
participant ":Systeme" as s
' Ajout des Pre conditions ici si nécessaire
activate e
e->s : gestionQuestions();
activate s
s-->>e : Liste des questions associées au cours
loop Tant que l'enseignant veut ajouter des questions
alt Ajout de Question Vrai ou Faux
e->s : ajouterQuestionVraiFaux(nom : String, enonce : String, verite : bool, retroactionVrai : String, retroactionFaux : String, tags : String[])
else Ajout d'autre type de question
 e->s : ajouterQuestionAutreType(nom : String, enonce : String, type : String, retroactionValide :String, retroactionInvalide : String, tags : String[])
end alt

alt Nom de question unique
    s-->>e : Liste des questions associées au cours mise à jour et confirmation de l'ajout
else Nom de question déjà utilisé
    s-->>e : Signalement d'erreur
end alt
end loop
deactivate s
deactivate e
@enduml