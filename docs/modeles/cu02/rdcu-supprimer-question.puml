@startuml
hide footbox
title RDCU – Supprimer une question (Demande)

participant "ui:UIQuestionsCours" as UI
participant "qc:QuestionsController" as QC
participant "qs:QuestionsStore" as QS

-> UI : supprimerQuestion(nom : String)
activate UI

UI -> QC : supprimerQuestion(groupId : String, nom : String)
activate QC

QC -> QS : questionUtiliseeDansQuestionnaire(groupId : String, nom : String)
activate QS
QS --> QC : utilisee : boolean
deactivate QS

alt Question non utilisee dans un questionnaire
  QC -> QS : chercherInfoQuestion(groupId : String, nom : String)
  activate QS
  QS --> QC : question:String
  deactivate QS

  QC --> UI : afficherInfoQuestionASupprimer(question):String
  QC --> UI : demanderConfirmationSuppression():String

  <-- UI : demandeConfirmationSuppression():String

else Question utilisee dans au moins un questionnaire
  QC -> QS : listerQuestionnairesUtilisantQuestion(groupId : String, nom : String)
  activate QS
  QS --> QC : questionnaires : List<Questionnaire>
  deactivate QS

  QC --> UI : afficherQuestionnairesUtilisantQuestion(questionnaires):String
  QC --> UI : desactiverSuppression():boolean
  deactivate QC

  <-- UI: suppressionImpossible():String
  deactivate UI
end

@enduml