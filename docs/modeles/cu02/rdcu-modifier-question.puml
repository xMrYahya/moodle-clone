@startuml
hide footbox
title RDCU – Modifier une question

participant "qc:QuestionsController" as QC
participant "cs:CoursStore" as CS
participant "q:Question" as Q

-> QC : modifierQuestion(groupId, nomOriginal, nom, enonce, type,\nretroactionValide, retroactionInvalide, tags, donneesType)
note right: GRASP: Controller
activate QC

QC -> CS : recupererQuestionParNom(groupId : String, nomOriginal : String)
note right: GRASP: Expert
activate CS
CS --> QC : questionExistante : Question
deactivate CS

alt Nom unique et donnees valides
  create Q
  QC -> Q : <<create>> Question(type, nom, enonce, retroactions, tags, donneesType)
  note right: GRASP: Creator
  activate Q
  deactivate Q

  QC -> CS : modifierQuestionDuCours(groupId : String, nomOriginal : String, q)
  note right: GRASP: Expert
  activate CS
  deactivate CS

  <-- QC : afficherConfirmationModification(questionMiseAJour)
else Nom deja utilise ou donnees invalides
  <-- QC : signalerErreurModification()
end

deactivate QC

@enduml