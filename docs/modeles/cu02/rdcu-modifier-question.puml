@startuml
hide footbox
title RDCU – Modifier une question Vrai ou Faux

participant "qc:QuestionsController" as QC
participant "cs:CoursStore" as CS
participant "q:QuestionVraiFaux" as Q

-> QC : modifierQuestionVraiFaux(nomOriginal : String, nom : String, enonce : String,\n reponse : bool, retroactionValide : String,\n retroactionInvalide : String, tags : String[])
note right: GRASP: Controller
activate QC

QC -> QC : validerDonnees(nom, enonce, reponse, tags)
note right: GRASP: Expert

QC -> CS : nomQuestionExisteSauf(groupId : String, nom : String, nomOriginal : String)
note right: GRASP: Expert
activate CS
CS --> QC : nomExiste : boolean
deactivate CS

alt Nom unique et donnees valides
  QC -> CS : recupererQuestionParNom(groupId : String, nomOriginal : String)
  note right: GRASP: Expert
  activate CS
  CS --> QC : questionExistante : Question
  deactivate CS

  create Q
  QC -> Q : <<create>> QuestionVraiFaux(nom, enonce, reponse,\n retroactionValide, retroactionInvalide, tags)
  note right: GRASP: Creator
  activate Q
  deactivate Q

  QC -> CS : modifierQuestionDuCours(groupId : String, nomOriginal : String, q)
  note right: GRASP: Expert
  activate CS
  deactivate CS

  <-- QC : afficherConfirmationModification(questionMiseAJour)
else Nom deja utilise ou donnees invalides
  <-- QC : signalerErreurModification()
end

deactivate QC

@enduml