@startuml
hide footbox
title RDCU - Modifier une question mise en correspondance

participant "qc:QuestionsController" as QC
participant "cm:CoursModele" as CM
participant "q:QuestionMiseEnCorrespondanceModele" as Q


-> QC : modifierQuestionMiseCorrespondance(nomOriginal : String, nom : String,\n enonce : String, pairesQuestion : String[], pairesReponse : String[], retroactionValide : String,\n retroactionInvalide : String, tags : String[])
note right: GRASP: Controller (Le nom de la fonction dans QuestionController est modifierQuestion)
activate QC

QC -> CM : obtenirQuestionParNom(idGroupe : String, nomOriginal : String)
note right: GRASP: Expert
activate CM
CM --> QC : questionExistante : AnyQuestion
deactivate CM

QC -> QC : validerChampsObligatoires(type:String, nom:String, enonce:String)
note right: GRASP: Expert

QC -> CM : validerNomQuestionUnique(idGroupe: String, nomFinal: String, nomOriginal: String)
note right: GRASP: Expert
activate CM
CM --> QC : nomExiste : boolean
deactivate CM

alt Nom unique et donnees valides
  QC -> QC : creerQuestionAutreType(type: string, nom: string, enonce: \nstring,retroactionValide: string, \nretroactionInvalide: string, tags: string[], autresDonnees: Record<string, unknown>)


  QC -> QC : lirePairesCorrespondance(paires)
  note right: GRASP: Expert

  create Q
  QC -> Q : <<create>> QuestionMiseEnCorrespondanceModele(nom:String, enonce:String,\n retroactionValide:String, retroactionInvalide:String, tags:String[], paires:String[])
  note right: GRASP: Creator
  activate Q
  deactivate Q

  QC -> CM : modifierQuestionDuCours(idGroupe : String, nomOriginal : String, q : QuestionMiseEnCorrespondance)
  note right: GRASP: Expert
  activate CM
  deactivate CM

  <-- QC : afficherConfirmationModification
else Nom deja utilise ou donnees invalides
  <-- QC : signalerErreurModification
end

deactivate QC
@enduml