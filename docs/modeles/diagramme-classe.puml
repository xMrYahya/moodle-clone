@startuml diagramme-classe
skinparam style strictuml
hide empty members

title Diagramme de classes

package "Integration SGB" {
  class SgbClient {
    -baseUrl: string
    +loginTeacher(email: string, password: string): Promise
    +getSchedules(token: string): Promise
    +getCourses(token: string): Promise
    +getGroupStudentLinks(token: string): Promise
    +getAllStudents(token: string): Promise
    +getEtudiantsParGroupe(token: string, idGroupe: string): Promise
    +getStudentsForGroup(token: string, idGroupe: string): Promise
    -construireGroupesCours(token: string, idEnseignant?: string): Promise
    +getCours(idEnseignant: string, token: string): Promise
    +getCoursParGroupe(idGroupe: string, token: string, idEnseignant?: string): Promise
    +getListeCours(idEnseignant: string, token: string): Promise
  }
}

package "Domaine" {
  abstract class Question {
    +nom: string
    +enonce: string
    +retroactionValide: string
    +retroactionInvalide: string
    +tags: string[]
    +{abstract} obtenirType(): string
  }

  class QuestionVraiFauxModele {
    +reponse: boolean
    +retroaction: string
    +obtenirType(): string
  }

  class QuestionChoixMultipleModele {
    +seulementUnChoix: boolean
    +reponses: ReponseChoixMultiple[]
    +obtenirType(): string
  }

  class QuestionMiseEnCorrespondanceModele {
    +paires: PairDeCorrespondance[]
    +obtenirType(): string
  }

  class QuestionReponseCourteModele {
    +reponseAttendue: string
    +retroaction: string
    +obtenirType(): string
  }

  class QuestionNumeriqueModele {
    +reponseAttendue: number
    +retroaction: string
    +obtenirType(): string
  }

  class QuestionEssaiModele {
    +obtenirType(): string
  }

  class ReponseChoixMultiple {
    +texte: string
    +estBonneReponse: boolean
    +retroaction: string
  }

  class PairDeCorrespondance {
    +question: string
    +reponse: string
  }

  class Cours {
    +idGroupe: string
    +jour: string
    +heure: string
    +activite: string
    +mode: string
    +local: string
    +idEnseignant: string
    +idCours: string
    +titreCours: string
    +etudiants: StudentInfo[]
    +questions: AnyQuestion[]
    +toPlainObject(): CoursInit
  }

  class Questionnaire {
    +nom: string
    +description: string
    +actif: boolean
    +questions: string[]
    +resultatsEtudiants: ResultatEtudiantQuestionnaire[]
    +creeLe: string
    +modifieLe: string
  }

  class ResultatEtudiantQuestionnaire {
    +courrielEtudiant: string
    +note: number
  }

  class QuestionnaireTemp {
    +mode: string
    +nomOriginal: string
    +nomQuestionnaire: string
    +description: string
    +actif: boolean
    +questions: string[]
  }

  class QuestionTagInfo {
    +nom: string
    +tags: string[]
    +utilisationQuestionnaires: number
  }
}

package "Modele" {
  class CoursModele {
    +{static} viderStoreAuDemarrage(): Promise
    +{static} obtenirCoursStockes(): Promise
    +{static} obtenirCoursStockesPourProf(idEnseignant: string): Promise
    +{static} obtenirCoursStockeParIdGroupe(idGroupe: string): Promise
    +{static} ajouterCoursStocke(cours: Cours): Promise
    +{static} retirerCoursStocke(idGroupe: string): Promise
    +{static} obtenirQuestionsDuCours(idGroupe: string): Promise
    +{static} nomQuestionExiste(idGroupe: string, nom: string): Promise
    +{static} nomQuestionExisteSauf(idGroupe: string, nom: string, nomAExclure: string): Promise
    +{static} obtenirQuestionParNom(idGroupe: string, nom: string): Promise
    +{static} ajouterQuestionAuCours(idGroupe: string, question: Question): Promise
    +{static} modifierQuestionDuCours(idGroupe: string, nomOriginal: string, questionMiseAJour: Question): Promise
    +{static} retirerQuestionDuCours(idGroupe: string, nom: string): Promise
  }

  class QuestionnaireModele {
    -{static} assurerFichierQuestionnaires(): Promise
    -{static} ecrireQuestionnairesParCours(donnees: StockageQuestionnairesParCours[]): Promise
    -{static} extraireTagsQuestion(question: AnyQuestion): string[]
    +{static} viderQuestionnairesAuDemarrage(): Promise
    +{static} obtenirTousQuestionnairesParCours(): Promise
    +{static} obtenirQuestionnairesAssocies(idGroupe: string): Promise
    +{static} obtenirQuestionnaireParNom(idGroupe: string, nomQuestionnaire: string): Promise
    +{static} verifierSupprimerQuestionnaire(idGroupe: string, nomQuestionnaire: string): Promise
    +{static} creerQuestionnaire(idGroupe: string, nom: string, description: string, actif: boolean): Promise
    +{static} ajouterQuestionnaire(idGroupe: string, questionnaire: Questionnaire): Promise
    +{static} sauvegarderQuestionnaire(idGroupe: string, nomQuestionnaire: string, questions: string[]): Promise
    +{static} supprimerQuestionnaire(idGroupe: string, nomQuestionnaire: string): Promise
    +{static} modifierQuestionnaire(idGroupe: string, nomOriginal: string, nom: string, description: string, actif: boolean, questions: string[]): Promise
    +{static} obtenirListeTagsDesQuestions(idGroupe: string): Promise
    +{static} obtenirQuestionParNom(idGroupe: string, nomQuestion: string): Promise
    +{static} obtenirQuestionsParTag(idGroupe: string, nomTag: string): Promise
    +{static} ajouterQuestion(questionnaireTemp: QuestionnaireTemp, nomQuestion: string): QuestionnaireTemp
    +{static} dissocierQuestion(questionnaireTemp: QuestionnaireTemp, nomQuestion: string): QuestionnaireTemp
    +{static} modifierOrdreQuestion(questionnaireTemp: QuestionnaireTemp, nomQuestion: string, nouvellePosition: number): QuestionnaireTemp
  }
}

package "Controleurs" {
  class AuthController {
    +{static} getSignin(req: Request, res: Response): void
    +{static} postSignin(req: Request, res: Response): Promise
    +{static} signout(req: Request, res: Response): void
  }

  class CoursController {
    +{static} demarrerAjoutCours(teacherId: string, token: string): Promise
    +{static} afficherListeCours(req: Request, res: Response): Promise
    +{static} index(req: Request, res: Response): Promise
    -{static} obtenirTypeQuestionPourAffichage(question: AnyQuestion): string
    +{static} selectionnerGroupeCours(req: Request, res: Response): Promise
    +{static} retirerCours(req: Request, res: Response): Promise
    +{static} confirmerSuppressionCours(req: Request, res: Response): Promise
    +{static} suppressionCours(req: Request, res: Response): Promise
    +{static} afficherDetailsCours(req: Request, res: Response): Promise
  }

  class QuestionsController {
    -{static} lireValeurSimple(valeur: unknown): unknown
    -{static} lireTexte(valeur: unknown): string
    -{static} lireBooleen(valeur: unknown): boolean
    -{static} lireNombre(valeur: unknown): number
    -{static} extraireContexteRequete(req: Request): ContexteRequete
    -{static} validerChampsObligatoires(donnees: Record, champsObligatoires: string[]): void
    -{static} validerNomQuestionUnique(idGroupe: string, nom: string, nomAExclure?: string): Promise
    -{static} validerTagsObligatoires(tags: unknown): string[]
    +{static} consulterQuestionsCours(req: Request, res: Response): Promise
    +{static} selectionnerQuestion(req: Request, res: Response): Promise
    +{static} modifierQuestion(req: Request, res: Response): Promise
    +{static} supprimerQuestion(req: Request, res: Response): Promise
    +{static} confirmerSuppressionQuestion(req: Request, res: Response): Promise
    -{static} lireTags(tags: unknown): string[]
    -{static} lireReponsesChoixMultiple(reponses: unknown): ReponseChoixMultiple[]
    -{static} lirePairesCorrespondance(paires: unknown): PairDeCorrespondance[]
    -{static} creerQuestionAutreType(type: string, nom: string, enonce: string, retroactionValide: string, retroactionInvalide: string, tags: string[]): Question
    +{static} ajouterQuestionVraiFaux(req: Request, res: Response): Promise
    -{static} ajouterQuestionParType(req: Request, res: Response, typeQuestion: string): Promise
    +{static} ajouterQuestionChoixMultiple(req: Request, res: Response): Promise
    +{static} ajouterQuestionNumerique(req: Request, res: Response): Promise
    +{static} ajouterQuestionReponseCourte(req: Request, res: Response): Promise
    +{static} ajouterQuestionMiseEnCorrespondance(req: Request, res: Response): Promise
    +{static} ajouterQuestionEssai(req: Request, res: Response): Promise
  }

  class QuestionnairesController {
    +{static} gererQuestionnaires(req: Request, res: Response): Promise
    +{static} ajouterQuestionnaire(req: Request, res: Response): Promise
    +{static} selectionnerTag(req: Request, res: Response): Promise
    +{static} ajouterQuestion(req: Request, res: Response): Promise
    +{static} sauvegarderQuestionnaire(req: Request, res: Response): Promise
    +{static} retirerQuestion(req: Request, res: Response): Promise
    +{static} selectionModifierQuestionnaire(req: Request, res: Response): Promise
    +{static} modifierOrdreQuestion(req: Request, res: Response): Promise
    +{static} modifierQuestionnaire(req: Request, res: Response): Promise
    +{static} verifierSupprimerQuestionnaire(req: Request, res: Response): Promise
    +{static} confirmerSuppression(req: Request, res: Response): Promise
  }
}

package "Application" {
  class App {
    +expressApp: express.Application
    -middleware(): void
    -handleErrors(error: Error, req: Request, res: Response, next: NextFunction): void
  }
}

Question <|-- QuestionVraiFauxModele
Question <|-- QuestionChoixMultipleModele
Question <|-- QuestionMiseEnCorrespondanceModele
Question <|-- QuestionReponseCourteModele
Question <|-- QuestionNumeriqueModele
Question <|-- QuestionEssaiModele

QuestionChoixMultipleModele "1" *-- "*" ReponseChoixMultiple
QuestionMiseEnCorrespondanceModele "1" *-- "*" PairDeCorrespondance
Cours "1" o-- "*" Question
Cours "1" o-- "*" Questionnaire
Questionnaire "1" o-- "*" ResultatEtudiantQuestionnaire
Questionnaire "*" -- "*" Question

AuthController --> SgbClient
CoursController --> SgbClient
CoursController ..> CoursModele
QuestionsController ..> CoursModele
QuestionsController ..> QuestionnaireModele
QuestionsController ..> QuestionVraiFauxModele
QuestionsController ..> QuestionChoixMultipleModele
QuestionsController ..> QuestionNumeriqueModele
QuestionsController ..> QuestionReponseCourteModele
QuestionsController ..> QuestionMiseEnCorrespondanceModele
QuestionsController ..> QuestionEssaiModele
QuestionnaireModele ..> CoursModele
QuestionnaireModele ..> Questionnaire
QuestionnaireModele ..> QuestionnaireTemp
QuestionnaireModele ..> QuestionTagInfo
QuestionnairesController ..> QuestionnaireModele
QuestionnairesController ..> CoursModele
CoursModele ..> Cours
App ..> CoursModele
App ..> QuestionnaireModele

@enduml
