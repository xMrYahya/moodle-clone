html
  include includes/head.pug

  body
    include includes/navbar.pug
    +navbar(displayName)

    .container.mt-4
      // ======================
      // ENTÊTE DU COURS
      // ======================
      .d-flex.justify-content-between.align-items-start.flex-wrap.gap-2
        .mb-2
          h1.mb-1 #{coursTitre}
          .text-muted.fs-5
            strong #{coursId}
            |  · Groupe: #{groupId}

          if cours
            .mt-2
              // un peu plus gros qu'avant
              .text-muted.fs-5
                | Horaire: #{cours.jour} · #{cours.heure}
                |  · Mode: #{cours.mode}
                |  · Local: #{cours.local}

      hr

      // ======================
      // SECTION QUESTIONS (EN HAUT)
      // ======================
      .card.mb-4
        .card-body
          .d-flex.justify-content-between.align-items-center.flex-wrap.gap-2
            h4.mb-0 Questions
            .d-flex.align-items-center.gap-2
              a.btn.btn-primary(href=`/cours/${groupId}/details-cours?addQuestion=1` id="btn-add-question") Ajouter une question

          if questions && questions.length
            .row.mt-3
              each q in questions
                .col-12.col-md-6.col-lg-4.mb-3
                  .card.h-100
                    .card-body
                      h5.card-title.mb-1 #{q.nom}
                      p.card-text.text-muted.mb-2
                        small Type: #{q.typeAffichage}
                      p.card-text.mb-2
                        em #{q.énoncé}
                      .d-flex.flex-wrap.gap-2.mt-3
                        button.btn.btn-sm.btn-outline-primary.js-btn-details(type="button" data-question-nom=q.nom) Détails
                        button.btn.btn-sm.btn-outline-warning.js-btn-edit(type="button" data-question-nom=q.nom) Modifier
                        button.btn.btn-sm.btn-outline-danger.js-btn-delete(type="button" data-question-nom=q.nom) Supprimer
          else
            p.text-muted.mt-3 Aucune question disponible.

      // ======================
      // SECTION ÉTUDIANTS (EN DESSOUS)
      // ======================
      .card.mb-4
        .card-body
          .d-flex.justify-content-between.align-items-center.flex-wrap.gap-2
            h4.mb-0 Étudiants
            if students && students.length
              span.badge.bg-secondary #{students.length}

          if students && students.length
            // petit champ de recherche simple côté client
            input.form-control.mt-3(type="text" id="student-search" placeholder="Rechercher un étudiant (prénom, nom ou email)...")

            .table-responsive.mt-3
              table.table.table-sm.table-striped.mb-0
                thead
                  tr
                    th Prénom
                    th Nom
                    th Email
                tbody#students-tbody
                  each st in students
                    tr.student-row
                      td #{st.first_name}
                      td #{st.last_name}
                      td #{st.email}
          else
            p.text-muted.mt-3 Aucun étudiant trouvé pour ce groupe.

    // ======================
    // MODAL : AJOUTER QUESTION
    // ======================
    if showAddQuestionModal
      .modal-overlay
        .modal-card
          .modal-header
            h5.mb-0#modal-title Choisir le type de question
            a.close(href=`/cours/${groupId}/details-cours` aria-label="Fermer") ×

          .modal-body
            // === ÉCRAN DE SÉLECTION DU TYPE ===
            #type-selection-screen
              p.text-muted.mb-4 Sélectionnez le type de question que vous souhaitez créer:
              .row
                .col-md-4.mb-3
                  .card.question-type-card(onclick="selectQuestionType('VraiFaux')" style="cursor: pointer;")
                    .card-body.text-center
                      h5.card-title.mb-0 Vrai ou Faux

                .col-md-4.mb-3
                  .card.question-type-card(onclick="selectQuestionType('ChoixMultiple')" style="cursor: pointer;")
                    .card-body.text-center
                      h5.card-title.mb-0 Choix Multiple

                .col-md-4.mb-3
                  .card.question-type-card(onclick="selectQuestionType('MiseEnCorrespondance')" style="cursor: pointer;")
                    .card-body.text-center
                      h5.card-title.mb-0 Mise en Correspondance

                .col-md-4.mb-3
                  .card.question-type-card(onclick="selectQuestionType('ReponseCourte')" style="cursor: pointer;")
                    .card-body.text-center
                      h5.card-title.mb-0 Réponse Courte

                .col-md-4.mb-3
                  .card.question-type-card(onclick="selectQuestionType('Numerique')" style="cursor: pointer;")
                    .card-body.text-center
                      h5.card-title.mb-0 Numérique

                .col-md-4.mb-3
                  .card.question-type-card(onclick="selectQuestionType('Essai')" style="cursor: pointer;")
                    .card-body.text-center
                      h5.card-title.mb-0 Essai

            // === FORMULAIRE VRAI/FAUX ===
            #form-screen-vraifaux(style="display: none;")
              button.btn.btn-sm.btn-link.mb-3(type="button" onclick="backToTypeSelection()") Retour

              form(method="post" action=`/questions/${groupId}/ajouter-vrai-faux` id="form-vrai-faux")
                h6.mb-3 Question Vrai ou Faux

                .form-group
                  label(for="nom-vf") Nom de la question:
                  input.form-control(type="text" id="nom-vf" name="nom" required)

                .form-group
                  label(for="enonce-vf") Énoncé:
                  textarea.form-control(id="enonce-vf" name="énoncé" required rows="3")

                .form-group
                  label(for="reponse-vf") Réponse correcte:
                  select.form-control(id="reponse-vf" name="reponse" required)
                    option(value="") -- Sélectionner --
                    option(value="true") Vrai
                    option(value="false") Faux

                .form-group
                  label(for="retroaction-valide-vf") Rétroaction si correct:
                  input.form-control(type="text" id="retroaction-valide-vf" name="retroactionValide" placeholder="Optionnel")

                .form-group
                  label(for="retroaction-invalide-vf") Rétroaction si incorrect:
                  input.form-control(type="text" id="retroaction-invalide-vf" name="retroactionInvalide" placeholder="Optionnel")

                .form-group
                  label(for="tags-vf") Tags (séparés par des virgules):
                  input.form-control(type="text" id="tags-vf" name="tags" placeholder="Optionnel")

                button.btn.btn-primary.w-100(type="submit") Ajouter cette question

            // === FORMULAIRE CHOIX MULTIPLE ===
            #form-screen-choixmultiple(style="display: none;")
              button.btn.btn-sm.btn-link.mb-3(type="button" onclick="backToTypeSelection()") Retour

              form(method="post" action=`/questions/${groupId}/ajouter-choix-multiple` id="form-choix-multiple")
                h6.mb-3 Question Choix Multiple

                .form-group
                  label(for="nom-cm") Nom de la question:
                  input.form-control(type="text" id="nom-cm" name="nom" required)

                .form-group
                  label(for="enonce-cm") Énoncé:
                  textarea.form-control(id="enonce-cm" name="énoncé" required rows="3")

                .form-group
                  .form-check.mb-2
                    input.form-check-input(type="checkbox" id="seul-choix-cm" name="seulementUnChoix" value="true")
                    label.form-check-label(for="seul-choix-cm") Un seul choix correct

                  .alert.alert-info.small
                    | Pour simplifier, entrez une description des choix. Format: "Choix1|Choix2|Choix3" (le premier est supposé correct)
                  label(for="rep-mult-cm") Description des choix:
                  input.form-control(type="text" id="rep-mult-cm" name="reponses" placeholder="Ex: Choix correct|Mauvais choix|Autre mauvais" required)

                .form-group
                  label(for="retroaction-valide-cm") Rétroaction si correct:
                  input.form-control(type="text" id="retroaction-valide-cm" name="retroactionValide" placeholder="Optionnel")

                .form-group
                  label(for="retroaction-invalide-cm") Rétroaction si incorrect:
                  input.form-control(type="text" id="retroaction-invalide-cm" name="retroactionInvalide" placeholder="Optionnel")

                .form-group
                  label(for="tags-cm") Tags (séparés par des virgules):
                  input.form-control(type="text" id="tags-cm" name="tags" placeholder="Optionnel")

                button.btn.btn-primary.w-100(type="submit") Ajouter cette question

            // === FORMULAIRE NUMÉRIQUE ===
            #form-screen-numerique(style="display: none;")
              button.btn.btn-sm.btn-link.mb-3(type="button" onclick="backToTypeSelection()") Retour

              form(method="post" action=`/questions/${groupId}/ajouter-numerique` id="form-numerique")
                h6.mb-3 Question Numérique

                .form-group
                  label(for="nom-num") Nom de la question:
                  input.form-control(type="text" id="nom-num" name="nom" required)

                .form-group
                  label(for="enonce-num") Énoncé:
                  textarea.form-control(id="enonce-num" name="énoncé" required rows="3")

                .form-group
                  label(for="reponse-num") Réponse numérique:
                  input.form-control(type="number" id="reponse-num" name="reponse" placeholder="Ex: 42" step="any" required)

                .form-group
                  label(for="retroaction-valide-num") Rétroaction si correct:
                  input.form-control(type="text" id="retroaction-valide-num" name="retroactionValide" placeholder="Optionnel")

                .form-group
                  label(for="retroaction-invalide-num") Rétroaction si incorrect:
                  input.form-control(type="text" id="retroaction-invalide-num" name="retroactionInvalide" placeholder="Optionnel")

                .form-group
                  label(for="tags-num") Tags (séparés par des virgules):
                  input.form-control(type="text" id="tags-num" name="tags" placeholder="Optionnel")

                button.btn.btn-primary.w-100(type="submit") Ajouter cette question

            // === FORMULAIRE RÉPONSE COURTE ===
            #form-screen-reponsecourte(style="display: none;")
              button.btn.btn-sm.btn-link.mb-3(type="button" onclick="backToTypeSelection()") Retour

              form(method="post" action=`/questions/${groupId}/ajouter-reponse-courte` id="form-reponse-courte")
                h6.mb-3 Question Réponse Courte

                .form-group
                  label(for="nom-rc") Nom de la question:
                  input.form-control(type="text" id="nom-rc" name="nom" required)

                .form-group
                  label(for="enonce-rc") Énoncé:
                  textarea.form-control(id="enonce-rc" name="énoncé" required rows="3")

                .form-group
                  label(for="reponse-rc") Réponse attendue:
                  input.form-control(type="text" id="reponse-rc" name="reponse" placeholder="La réponse correcte" required)

                .form-group
                  label(for="retroaction-valide-rc") Rétroaction si correct:
                  input.form-control(type="text" id="retroaction-valide-rc" name="retroactionValide" placeholder="Optionnel")

                .form-group
                  label(for="retroaction-invalide-rc") Rétroaction si incorrect:
                  input.form-control(type="text" id="retroaction-invalide-rc" name="retroactionInvalide" placeholder="Optionnel")

                .form-group
                  label(for="tags-rc") Tags (séparés par des virgules):
                  input.form-control(type="text" id="tags-rc" name="tags" placeholder="Optionnel")

                button.btn.btn-primary.w-100(type="submit") Ajouter cette question

            // === FORMULAIRE MISE EN CORRESPONDANCE ===
            #form-screen-miseencorrespondance(style="display: none;")
              button.btn.btn-sm.btn-link.mb-3(type="button" onclick="backToTypeSelection()") Retour

              form(method="post" action=`/questions/${groupId}/ajouter-mise-en-correspondance` id="form-mise-correspondance")
                h6.mb-3 Question Mise en Correspondance

                .form-group
                  label(for="nom-mec") Nom de la question:
                  input.form-control(type="text" id="nom-mec" name="nom" required)

                .form-group
                  label(for="enonce-mec") Énoncé:
                  textarea.form-control(id="enonce-mec" name="énoncé" required rows="3")

                .form-group
                  .alert.alert-info.small
                    | Pour simplifier, entrez les paires de correspondance. Format: "Question1:Réponse1|Question2:Réponse2"
                  label(for="paires-mec") Paires de correspondance:
                  input.form-control(type="text" id="paires-mec" name="paires" placeholder="Ex: Paris:France|Berlin:Allemagne|Tokyo:Japon" required)

                .form-group
                  label(for="retroaction-valide-mec") Rétroaction si correct:
                  input.form-control(type="text" id="retroaction-valide-mec" name="retroactionValide" placeholder="Optionnel")

                .form-group
                  label(for="retroaction-invalide-mec") Rétroaction si incorrect:
                  input.form-control(type="text" id="retroaction-invalide-mec" name="retroactionInvalide" placeholder="Optionnel")

                .form-group
                  label(for="tags-mec") Tags (séparés par des virgules):
                  input.form-control(type="text" id="tags-mec" name="tags" placeholder="Optionnel")

                button.btn.btn-primary.w-100(type="submit") Ajouter cette question

            // === FORMULAIRE ESSAI ===
            #form-screen-essai(style="display: none;")
              button.btn.btn-sm.btn-link.mb-3(type="button" onclick="backToTypeSelection()") Retour

              form(method="post" action=`/questions/${groupId}/ajouter-essai` id="form-essai")
                h6.mb-3 Question Essai

                .form-group
                  label(for="nom-essai") Nom de la question:
                  input.form-control(type="text" id="nom-essai" name="nom" required)

                .form-group
                  label(for="enonce-essai") Énoncé:
                  textarea.form-control(id="enonce-essai" name="énoncé" required rows="5")

                .alert.alert-info.small
                  | Les questions de type essai sont des questions ouvertes qui nécessitent une correction manuelle.

                .form-group
                  label(for="retroaction-valide-essai") Rétroaction si correct:
                  input.form-control(type="text" id="retroaction-valide-essai" name="retroactionValide" placeholder="Optionnel")

                .form-group
                  label(for="retroaction-invalide-essai") Rétroaction si incorrect:
                  input.form-control(type="text" id="retroaction-invalide-essai" name="retroactionInvalide" placeholder="Optionnel")

                .form-group
                  label(for="tags-essai") Tags (séparés par des virgules):
                  input.form-control(type="text" id="tags-essai" name="tags" placeholder="Optionnel")

                button.btn.btn-primary.w-100(type="submit") Ajouter cette question

          .modal-footer
            a.btn.btn-secondary(href=`/cours/${groupId}/details-cours`) Fermer

    // ======================
    // MODAL : DÉTAIL QUESTION (CU02b)
    // ======================
    .modal-overlay#question-details-modal(style="display: none;")
      .modal-card
        .modal-header
          h5.mb-0 Détails de la question
          button.close.js-close-details(type="button" aria-label="Fermer") ×
        .modal-body
          dl.row.mb-0
            dt.col-sm-4 Type
            dd.col-sm-8#details-type -
            dt.col-sm-4 Nom
            dd.col-sm-8#details-nom -
            dt.col-sm-4 Énoncé
            dd.col-sm-8#details-enonce -
            dt.col-sm-4 Réponse/Valeur
            dd.col-sm-8#details-reponse -
            dt.col-sm-4 Rétroaction valide
            dd.col-sm-8#details-retro-valide -
            dt.col-sm-4 Rétroaction invalide
            dd.col-sm-8#details-retro-invalide -
            dt.col-sm-4 Tags
            dd.col-sm-8#details-tags -
        .modal-footer
          button.btn.btn-secondary.js-close-details(type="button") Fermer

    // ======================
    // MODAL : MODIFIER QUESTION (CU02c)
    // ======================
    .modal-overlay#question-edit-modal(style="display: none;")
      .modal-card
        .modal-header
          h5.mb-0 Modifier la question
          button.close.js-close-edit(type="button" aria-label="Fermer") ×
        .modal-body
          form#question-edit-form
            .form-group
              label(for="edit-type") Type
              select.form-control#edit-type(name="type" required)
                option(value="VraiFaux") Vrai ou Faux
                option(value="ChoixMultiple") Choix Multiple
                option(value="MiseEnCorrespondance") Mise en Correspondance
                option(value="ReponseCourte") Réponse Courte
                option(value="Numerique") Numérique
                option(value="Essai") Essai

            .form-group
              label(for="edit-nom") Nom
              input.form-control#edit-nom(type="text" name="nom" required)

            .form-group
              label(for="edit-enonce") Énoncé
              textarea.form-control#edit-enonce(name="énoncé" rows="3" required)

            .form-group
              label(for="edit-retroaction-valide") Rétroaction valide
              input.form-control#edit-retroaction-valide(type="text" name="retroactionValide")

            .form-group
              label(for="edit-retroaction-invalide") Rétroaction invalide
              input.form-control#edit-retroaction-invalide(type="text" name="retroactionInvalide")

            .form-group
              label(for="edit-tags") Tags (séparés par des virgules)
              input.form-control#edit-tags(type="text" name="tags")

            #edit-field-vf(style="display: none;")
              .form-group
                label(for="edit-reponse-vf") Réponse correcte
                select.form-control#edit-reponse-vf(name="reponse")
                  option(value="true") Vrai
                  option(value="false") Faux

            #edit-field-cm(style="display: none;")
              .form-group
                .form-check.mb-2
                  input.form-check-input#edit-seulement-un-choix(type="checkbox" name="seulementUnChoix" value="true")
                  label.form-check-label(for="edit-seulement-un-choix") Un seul choix correct
              .form-group
                label(for="edit-reponses-cm") Réponses (format: choix1|choix2|choix3)
                input.form-control#edit-reponses-cm(type="text" name="reponses")

            #edit-field-mec(style="display: none;")
              .form-group
                label(for="edit-paires-mec") Paires (format: question:réponse|question:réponse)
                input.form-control#edit-paires-mec(type="text" name="paires")

            #edit-field-reponse(style="display: none;")
              .form-group
                label(for="edit-reponse") Réponse attendue
                input.form-control#edit-reponse(type="text" name="reponse")

            .d-flex.justify-content-end.gap-2
              button.btn.btn-secondary.js-close-edit(type="button") Annuler
              button.btn.btn-primary(type="submit") Enregistrer

    // ======================
    // MODAL : CONFIRMER SUPPRESSION (CU02d)
    // ======================
    .modal-overlay#question-delete-modal(style="display: none;")
      .modal-card
        .modal-header
          h5.mb-0 Confirmation de suppression
          button.close.js-close-delete(type="button" aria-label="Fermer") ×
        .modal-body
          p.mb-2 Voulez-vous vraiment supprimer cette question ?
          p.text-muted.mb-0#delete-question-name -
        .modal-footer
          button.btn.btn-secondary.js-close-delete(type="button") Annuler
          button.btn.btn-danger#confirm-delete-question(type="button") Confirmer la suppression

    style.
      .question-type-card:hover {
        background-color: #f8f9fa;
        border-color: #007bff;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        transition: all 0.2s;
      }
      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 16px;
      }
      .modal-card {
        width: 100%;
        max-width: 900px;
        background: white;
        border-radius: 12px;
        overflow: hidden;
      }
      .modal-header, .modal-footer {
        padding: 12px 16px;
        border-bottom: 1px solid #eee;
      }
      .modal-footer {
        border-top: 1px solid #eee;
        border-bottom: none;
      }
      .modal-body {
        padding: 16px;
        max-height: 75vh;
        overflow: auto;
      }

    script.
      const groupId = "#{groupId}";

      // Simple search étudiants
      const searchInput = document.getElementById('student-search');
      if (searchInput) {
        searchInput.addEventListener('input', function() {
          const q = (this.value || '').toLowerCase();
          document.querySelectorAll('.student-row').forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(q) ? '' : 'none';
          });
        });
      }

      function selectQuestionType(type) {
        document.getElementById('type-selection-screen').style.display = 'none';
        const screenMap = {
          'VraiFaux': 'form-screen-vraifaux',
          'ChoixMultiple': 'form-screen-choixmultiple',
          'Numerique': 'form-screen-numerique',
          'ReponseCourte': 'form-screen-reponsecourte',
          'MiseEnCorrespondance': 'form-screen-miseencorrespondance',
          'Essai': 'form-screen-essai'
        };
        const screenId = screenMap[type];
        if (screenId) {
          document.getElementById(screenId).style.display = 'block';
          const titleMap = {
            'VraiFaux': 'Question Vrai ou Faux',
            'ChoixMultiple': 'Question Choix Multiple',
            'Numerique': 'Question Numérique',
            'ReponseCourte': 'Question Réponse Courte',
            'MiseEnCorrespondance': 'Question Mise en Correspondance',
            'Essai': 'Question Essai'
          };
          document.getElementById('modal-title').textContent = titleMap[type];
        }
      }

      function backToTypeSelection() {
        ['vraifaux','choixmultiple','numerique','reponsecourte','miseencorrespondance','essai']
          .forEach(id => {
            const el = document.getElementById(`form-screen-${id}`);
            if (el) el.style.display = 'none';
          });
        document.getElementById('type-selection-screen').style.display = 'block';
        document.getElementById('modal-title').textContent = 'Choisir le type de question';
      }

      // IMPORTANT: rendre les fonctions accessibles pour les onclick=""
      window.selectQuestionType = selectQuestionType;
      window.backToTypeSelection = backToTypeSelection;

      function formDataToJson(formData) {
        const json = {};
        formData.forEach((value, key) => {
          if (json[key]) {
            if (!Array.isArray(json[key])) json[key] = [json[key]];
            json[key].push(value);
          } else {
            json[key] = value;
          }
        });
        return json;
      }

      async function handleFormSubmit(e, requiredFields) {
        e.preventDefault();
        try {
          const formData = new FormData(e.target);
          const data = formDataToJson(formData);

          const missing = requiredFields.filter(field => !data[field] || String(data[field]).trim() === '');
          if (missing.length > 0) {
            alert('Erreur: Veuillez remplir tous les champs obligatoires (' + missing.join(', ') + ')');
            return;
          }

          const response = await fetch(e.target.action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          if (!response.ok) {
            let errPayload = null;
            try { errPayload = await response.json(); } catch {}
            alert('Erreur: ' + (errPayload?.error || response.statusText || 'Erreur lors de l\'ajout'));
            return;
          }

          const result = await response.json();

          // cache-buster pour éviter le 304
          window.location.href = `/cours/${groupId}/details-cours?ts=${Date.now()}`;
        } catch (err) {
          alert('Erreur: ' + err.message);
        }
      }

      const fVf = document.getElementById('form-vrai-faux');
      if (fVf) fVf.addEventListener('submit', e => handleFormSubmit(e, ['nom', 'énoncé', 'reponse']));

      const fCm = document.getElementById('form-choix-multiple');
      if (fCm) fCm.addEventListener('submit', e => handleFormSubmit(e, ['nom', 'énoncé', 'reponses']));

      const fNum = document.getElementById('form-numerique');
      if (fNum) fNum.addEventListener('submit', e => handleFormSubmit(e, ['nom', 'énoncé', 'reponse']));

      const fRc = document.getElementById('form-reponse-courte');
      if (fRc) fRc.addEventListener('submit', e => handleFormSubmit(e, ['nom', 'énoncé', 'reponse']));

      const fMec = document.getElementById('form-mise-correspondance');
      if (fMec) fMec.addEventListener('submit', e => handleFormSubmit(e, ['nom', 'énoncé', 'paires']));

      const fEss = document.getElementById('form-essai');
      if (fEss) fEss.addEventListener('submit', e => handleFormSubmit(e, ['nom', 'énoncé']));

      const detailsModal = document.getElementById('question-details-modal');
      const editModal = document.getElementById('question-edit-modal');
      const deleteModal = document.getElementById('question-delete-modal');

      let questionEnCoursModification = null;
      let questionEnCoursSuppression = null;

      function ouvrirModal(modal) {
        if (modal) {
          modal.style.display = 'flex';
        }
      }

      function fermerModal(modal) {
        if (modal) {
          modal.style.display = 'none';
        }
      }

      async function fetchQuestionParNom(nomQuestion) {
        const url = `/questions/${groupId}/questions/${encodeURIComponent(nomQuestion)}`;
        const response = await fetch(url, { method: 'GET' });
        if (!response.ok) {
          let errPayload = null;
          try { errPayload = await response.json(); } catch {}
          throw new Error(errPayload?.error || response.statusText || 'Erreur lors de la récupération de la question');
        }
        const payload = await response.json();
        return payload.question;
      }

      function extraireValeurReponse(question) {
        if (!question) return '-';
        if (question.type === 'VraiFaux') return String(question.reponse);
        if (question.type === 'Numerique') return String(question.reponseAttendue ?? '-');
        if (question.type === 'ReponseCourte') return String(question.reponseAttendue ?? '-');
        if (question.type === 'ChoixMultiple') {
          const reponses = Array.isArray(question.reponses) ? question.reponses.map(r => r.text) : [];
          return reponses.length ? reponses.join(' | ') : '-';
        }
        if (question.type === 'MiseEnCorrespondance') {
          const paires = Array.isArray(question.paires)
            ? question.paires.map(p => `${p.question}:${p.reponse}`)
            : [];
          return paires.length ? paires.join(' | ') : '-';
        }
        return '-';
      }

      function afficherDetailsQuestion(question) {
        document.getElementById('details-type').textContent = question?.type || '-';
        document.getElementById('details-nom').textContent = question?.nom || '-';
        document.getElementById('details-enonce').textContent = question?.['énoncé'] || '-';
        document.getElementById('details-reponse').textContent = extraireValeurReponse(question);
        document.getElementById('details-retro-valide').textContent = question?.retroactionValide || '-';
        document.getElementById('details-retro-invalide').textContent = question?.retroactionInvalide || '-';
        const tags = Array.isArray(question?.tags) ? question.tags.join(', ') : '';
        document.getElementById('details-tags').textContent = tags || '-';
      }

      function afficherChampsModification(typeQuestion) {
        const vf = document.getElementById('edit-field-vf');
        const cm = document.getElementById('edit-field-cm');
        const mec = document.getElementById('edit-field-mec');
        const rep = document.getElementById('edit-field-reponse');

        [vf, cm, mec, rep].forEach(el => {
          if (el) el.style.display = 'none';
        });

        if (typeQuestion === 'VraiFaux' && vf) vf.style.display = 'block';
        if (typeQuestion === 'ChoixMultiple' && cm) cm.style.display = 'block';
        if (typeQuestion === 'MiseEnCorrespondance' && mec) mec.style.display = 'block';
        if ((typeQuestion === 'ReponseCourte' || typeQuestion === 'Numerique') && rep) rep.style.display = 'block';
      }

      function preRemplirFormulaireModification(question) {
        document.getElementById('edit-type').value = question.type;
        document.getElementById('edit-nom').value = question.nom || '';
        document.getElementById('edit-enonce').value = question['énoncé'] || '';
        document.getElementById('edit-retroaction-valide').value = question.retroactionValide || '';
        document.getElementById('edit-retroaction-invalide').value = question.retroactionInvalide || '';
        document.getElementById('edit-tags').value = Array.isArray(question.tags) ? question.tags.join(', ') : '';

        const champReponseVF = document.getElementById('edit-reponse-vf');
        if (champReponseVF) {
          champReponseVF.value = question.reponse === true ? 'true' : 'false';
        }

        const seulementUnChoix = document.getElementById('edit-seulement-un-choix');
        if (seulementUnChoix) {
          seulementUnChoix.checked = question.seulementUnChoix === true;
        }

        const champReponsesCM = document.getElementById('edit-reponses-cm');
        if (champReponsesCM) {
          const reponses = Array.isArray(question.reponses) ? question.reponses.map(r => r.text) : [];
          champReponsesCM.value = reponses.join('|');
        }

        const champPaires = document.getElementById('edit-paires-mec');
        if (champPaires) {
          const paires = Array.isArray(question.paires)
            ? question.paires.map(p => `${p.question}:${p.reponse}`)
            : [];
          champPaires.value = paires.join('|');
        }

        const champReponse = document.getElementById('edit-reponse');
        if (champReponse) {
          if (question.type === 'Numerique' || question.type === 'ReponseCourte') {
            champReponse.value = String(question.reponseAttendue ?? '');
          } else {
            champReponse.value = '';
          }
        }

        afficherChampsModification(question.type);
      }

      document.querySelectorAll('.js-btn-details').forEach(btn => {
        btn.addEventListener('click', async function() {
          try {
            const nom = this.dataset.questionNom;
            const question = await fetchQuestionParNom(nom);
            afficherDetailsQuestion(question);
            ouvrirModal(detailsModal);
          } catch (err) {
            alert('Erreur: ' + err.message);
          }
        });
      });

      document.querySelectorAll('.js-btn-edit').forEach(btn => {
        btn.addEventListener('click', async function() {
          try {
            const nom = this.dataset.questionNom;
            const question = await fetchQuestionParNom(nom);
            questionEnCoursModification = question.nom;
            preRemplirFormulaireModification(question);
            ouvrirModal(editModal);
          } catch (err) {
            alert('Erreur: ' + err.message);
          }
        });
      });

      document.querySelectorAll('.js-btn-delete').forEach(btn => {
        btn.addEventListener('click', async function() {
          try {
            const nom = this.dataset.questionNom;
            const url = `/questions/${groupId}/questions/${encodeURIComponent(nom)}/suppression`;
            const response = await fetch(url, { method: 'GET' });
            if (!response.ok) {
              let errPayload = null;
              try { errPayload = await response.json(); } catch {}
              throw new Error(errPayload?.error || response.statusText || 'Erreur lors de la préparation de la suppression');
            }

            const payload = await response.json();
            questionEnCoursSuppression = payload?.question?.nom || nom;
            document.getElementById('delete-question-name').textContent = questionEnCoursSuppression;
            ouvrirModal(deleteModal);
          } catch (err) {
            alert('Erreur: ' + err.message);
          }
        });
      });

      const editType = document.getElementById('edit-type');
      if (editType) {
        editType.addEventListener('change', function() {
          afficherChampsModification(this.value);
        });
      }

      const editForm = document.getElementById('question-edit-form');
      if (editForm) {
        editForm.addEventListener('submit', async function(e) {
          e.preventDefault();

          if (!questionEnCoursModification) {
            alert('Erreur: aucune question sélectionnée pour modification');
            return;
          }

          try {
            const formData = new FormData(editForm);
            const data = formDataToJson(formData);

            if (!data.nom || !String(data.nom).trim() || !data['énoncé'] || !String(data['énoncé']).trim()) {
              alert('Erreur: Veuillez remplir les champs obligatoires (nom, énoncé)');
              return;
            }

            if (data.type === 'VraiFaux' && (!data.reponse || String(data.reponse).trim() === '')) {
              alert('Erreur: la réponse est obligatoire pour une question vrai/faux');
              return;
            }

            const url = `/questions/${groupId}/questions/${encodeURIComponent(questionEnCoursModification)}/modifier`;
            const response = await fetch(url, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            });

            if (!response.ok) {
              let errPayload = null;
              try { errPayload = await response.json(); } catch {}
              throw new Error(errPayload?.error || response.statusText || 'Erreur lors de la modification');
            }

            window.location.href = `/cours/${groupId}/details-cours?ts=${Date.now()}`;
          } catch (err) {
            alert('Erreur: ' + err.message);
          }
        });
      }

      const confirmerSuppression = document.getElementById('confirm-delete-question');
      if (confirmerSuppression) {
        confirmerSuppression.addEventListener('click', async function() {
          if (!questionEnCoursSuppression) {
            alert('Erreur: aucune question sélectionnée pour suppression');
            return;
          }

          try {
            const url = `/questions/${groupId}/questions/${encodeURIComponent(questionEnCoursSuppression)}/suppression`;
            const response = await fetch(url, { method: 'POST' });
            if (!response.ok) {
              let errPayload = null;
              try { errPayload = await response.json(); } catch {}
              throw new Error(errPayload?.error || response.statusText || 'Erreur lors de la suppression');
            }

            window.location.href = `/cours/${groupId}/details-cours?ts=${Date.now()}`;
          } catch (err) {
            alert('Erreur: ' + err.message);
          }
        });
      }

      document.querySelectorAll('.js-close-details').forEach(btn => {
        btn.addEventListener('click', () => fermerModal(detailsModal));
      });

      document.querySelectorAll('.js-close-edit').forEach(btn => {
        btn.addEventListener('click', () => {
          questionEnCoursModification = null;
          fermerModal(editModal);
        });
      });

      document.querySelectorAll('.js-close-delete').forEach(btn => {
        btn.addEventListener('click', () => {
          questionEnCoursSuppression = null;
          fermerModal(deleteModal);
        });
      });

      // ---- Format affichage (minimal) : Jeu->Jeudi, P/D -> Présentiel/Distance ----
      // On modifie juste le texte déjà rendu, sans toucher au backend.
      (function normalizeCourseInfo() {
        const blocks = document.querySelectorAll('.container .text-muted.fs-5');
        blocks.forEach(b => {
          b.innerHTML = b.innerHTML
            .replace(/\bJeu\b/g, 'Jeudi')
            .replace(/\bP\b/g, 'Présentiel')
            .replace(/\bD\b/g, 'Distance');
        });
      })();
