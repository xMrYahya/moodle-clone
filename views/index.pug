html
  include includes/head.pug

  body
    include includes/navbar.pug
    +navbar(displayName)

    .container.mt-4
      if isStudent
        h1 Mes cours
      else
        h1 Accueil

      if messageSucces
        .alert.alert-success.mt-3.alert-fermeture
          span #{messageSucces}
          button.btn-fermer-alerte(type="button" aria-label="Fermer" onclick="fermerAlerte(this)") x
      if messageErreur
        .alert.alert-danger.mt-3.alert-fermeture
          span #{messageErreur}
          button.btn-fermer-alerte(type="button" aria-label="Fermer" onclick="fermerAlerte(this)") x

      if !isStudent
        a.btn.btn-primary(href="/index?addCourse=1") Ajouter cours

      hr

      // ======================
      // TUILES DES COURS CRÉÉS
      // ======================
      if isStudent
        if studentGroups && studentGroups.length
          .row.mt-3
            each g in studentGroups
              a.col-12.col-md-6.col-lg-4.mb-3(href=`/cours/${g.idGroupe}/questionnaires/etudiant` style="text-decoration: none; color: inherit;")
                .card.h-100
                  .card-body
                    h5.card-title.mb-1 #{g.idCours} · #{g.titreCours || g.activite}
                    p.card-text.text-muted.mb-0 #{g.idGroupe}
        else
          p.text-muted.mt-3 Aucun cours disponible pour cet etudiant.
      else if createdGroups && createdGroups.length
        .row.mt-3
          each g in createdGroups
            a.col-12.col-md-6.col-lg-4.mb-3(href=`/cours/${g.idGroupe}/details-cours` style="text-decoration: none; color: inherit;")
              .card.h-100
                .card-body
                  h5.card-title.mb-1 #{g.idCours} · #{g.titreCours || g.activite}
                  p.card-text.text-muted.mb-3 #{g.idGroupe}

                  .d-flex.gap-2
                    button.btn.btn-sm.btn-outline-danger(
                      type="button"
                      onclick=`event.preventDefault(); window.location.href='/cours/retirer-cours?idCours=${encodeURIComponent(g.idGroupe)}'`
                    ) Retirer
      else
        p.text-muted.mt-3 Aucun cours pour l’instant.

    // ======================
    // POPUP : AJOUT DE COURS
    // ======================
    if showAddCourseModal
      .modal-overlay
        .modal-card
          .modal-header
            h5.mb-0 Ajouter un groupe-cours
            a.close(href="/index" aria-label="Fermer") ×

          .modal-body
            if !groups || groups.length === 0
              p.text-muted Aucun groupe-cours disponible.
            else
              ul.list-group
                each g in groups
                  li.list-group-item.d-flex.justify-content-between.align-items-center
                    div
                      strong #{g.idCours} · #{g.titreCours || g.activite}
                      br
                      small.text-muted #{g.idGroupe}

                    form(method="post" action="/cours/selectionner-groupe-cours" class="m-0")
                      input(type="hidden" name="idGroupe" value=g.idGroupe)
                      input(type="hidden" name="courseId" value=g.idCours)
                      input(type="hidden" name="courseTitre" value=g.titreCours)
                      button.btn.btn-sm.btn-outline-primary(type="submit") Créer

          .modal-footer
            a.btn.btn-secondary(href="/index") Fermer

    // ======================
    // POPUP : CONFIRMER RETRAIT
    // ======================
    if confirmRemoveGroupId
      .modal-overlay
        .modal-card
          .modal-header
            h5.mb-0 Confirmer le retrait
            a.close(href="/index" aria-label="Fermer") ×

          .modal-body
            p.mb-0 Es-tu sûr de vouloir retirer ce cours ?
            p.text-muted.mt-2.mb-0 #{confirmRemoveGroupId}

          .modal-footer
            a.btn.btn-secondary(href="/index") Annuler
            form(method="post" action="/cours/suppression-cours" class="m-0")
              input(type="hidden" name="idCours" value=confirmRemoveGroupId)
              button.btn.btn-danger(type="submit") Oui, retirer

    style.
      .alert-fermeture {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
      }
      .btn-fermer-alerte {
        border: none;
        background: transparent;
        font-weight: bold;
        font-size: 18px;
        line-height: 1;
        cursor: pointer;
        opacity: 0.75;
      }
      .btn-fermer-alerte:hover {
        opacity: 1;
      }

    script.
      function nettoyerParametresFlashUrl() {
        const url = new URL(window.location.href);
        const hadSucces = url.searchParams.has("succes");
        const hadErreur = url.searchParams.has("erreur");
        if (!hadSucces && !hadErreur) {
          return;
        }
        url.searchParams.delete("succes");
        url.searchParams.delete("erreur");
        const nouvelleUrl = `${url.pathname}${url.searchParams.toString() ? `?${url.searchParams.toString()}` : ""}${url.hash || ""}`;
        window.history.replaceState({}, "", nouvelleUrl);
      }
      function fermerAlerte(btn) {
        const alerte = btn && btn.closest('.alert');
        if (alerte) {
          alerte.remove();
        }
        nettoyerParametresFlashUrl();
      }
      window.fermerAlerte = fermerAlerte;
      nettoyerParametresFlashUrl();
